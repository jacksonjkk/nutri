# Django Core Settings
DJANGO_SECRET_KEY=your_secret_key_here
DJANGO_DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com

# Database (PostgreSQL)
# Option 1: Use a single URL (Standard for Render/Heroku)
DATABASE_URL=postgres://user:password@hostname:5432/dbname
# Option 2: Individual variables
DB_NAME=myproject
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=dpg-xxxxx-a.oregon-postgres.render.com
DB_PORT=5432

# AI / Intelligence Layer
# Critical for Groq Llama-3 "Brain"
GROQ_API_KEY=your_groq_api_key_here

# Celery & Redis (Performance Layer)
CELERY_BROKER_URL=redis://your-redis-url:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-url:6379/0

# Email Alerts (Clinical Notifications)
# Default is Brevo (Sendinblue)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@domain.com
EMAIL_HOST_PASSWORD=your_smtp_key_here
DEFAULT_FROM_EMAIL=jackjunior301010@gmail.com

# CORS Settings
# Allow the frontend to talk to this backend
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173
